# Postgres connection string.
# For local development we recommend using Neon (free tier): https://neon.tech
# After creating a project, copy the "Connection string" from the Neon dashboard.
DATABASE_URL=postgres://user:password@host/urbannode?sslmode=require

# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

PORT=3001

# Google Gemini API key for AI features (leave blank until needed).
GEMINI_API_KEY=
